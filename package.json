{
  "name": "@schedulespark/date-picker",
  "version": "0.0.1-beta-3-0-0",
  "description": "Framework-free month-grid calendar/date picker for ScheduleSpark scheduling forms.",
  "license": "MIT",
  "author": "Stephen M",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "docs",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schedulespark/date-picker.git"
  },
  "keywords": [
    "date-picker",
    "calendar",
    "schedule",
    "vanilla",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp src/styles.css dist/styles.css",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
